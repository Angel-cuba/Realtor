{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@realtor/domain": ["packages/domain/src"],
      "@realtor/domain/*": ["packages/domain/src/*"],
      "@realtor/db": ["packages/db/src"],
      "@realtor/db/*": ["packages/db/src/*"],
      "@realtor/i18n": ["packages/i18n/src"],
      "@realtor/i18n/*": ["packages/i18n/src/*"]
    }
  }
}
