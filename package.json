{
  "name": "realtor-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.10.0",
  "engines": {
    "node": ">=24.3.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "npm run dev --workspace @realtor/web",
    "dev:mobile": "npm run dev --workspace @realtor/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "overrides": {
    "electron-to-chromium": "1.5.374"
  },
  "devDependencies": {
    "@vercel/config": "0.5.2",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  }
}
